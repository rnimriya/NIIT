# Next.js web app (pnpm monorepo)
FROM node:20-slim AS base
RUN corepack enable
WORKDIR /repo

FROM base AS build
ARG NEXT_PUBLIC_AI_URL=http://localhost:4001
ARG NEXT_PUBLIC_AUTH_URL=http://localhost:4002
ARG NEXT_PUBLIC_TESTS_URL=http://localhost:4003
ARG NEXT_PUBLIC_PREDICTION_URL=http://localhost:4004
ARG NEXT_PUBLIC_STUDY_URL=http://localhost:4005
ARG NEXT_PUBLIC_PAYMENTS_URL=http://localhost:4006
ARG NEXT_PUBLIC_NOTIFICATIONS_URL=http://localhost:4007
ENV NEXT_PUBLIC_AI_URL=$NEXT_PUBLIC_AI_URL
ENV NEXT_PUBLIC_AUTH_URL=$NEXT_PUBLIC_AUTH_URL
ENV NEXT_PUBLIC_TESTS_URL=$NEXT_PUBLIC_TESTS_URL
ENV NEXT_PUBLIC_PREDICTION_URL=$NEXT_PUBLIC_PREDICTION_URL
ENV NEXT_PUBLIC_STUDY_URL=$NEXT_PUBLIC_STUDY_URL
ENV NEXT_PUBLIC_PAYMENTS_URL=$NEXT_PUBLIC_PAYMENTS_URL
ENV NEXT_PUBLIC_NOTIFICATIONS_URL=$NEXT_PUBLIC_NOTIFICATIONS_URL
COPY pnpm-workspace.yaml package.json ./
COPY apps/web ./apps/web
RUN pnpm install --frozen-lockfile=false
RUN pnpm --filter @neet/web build

FROM base AS runtime
ENV NODE_ENV=production
COPY --from=build /repo /repo
WORKDIR /repo/apps/web
EXPOSE 3000
CMD ["pnpm", "start"]
